{
    "name": "psc-acme/lib-billing",
    "description": "Package lib-billing for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\LibBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/uid": "^7.0",
        "psr/container": "^2.0",
        "psc-acme/driver-payment": "^1.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "symfony/phpunit-bridge": "^7.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}